# =============================================================================
# ANGLERFISH · Claude Fable 5 — Autotrade Engine
# .env.example — Template การตั้งค่า / Configuration template
#
# วิธีใช้ / How to use:
#   1) คัดลอกไฟล์นี้เป็น .env: cp .env.example .env
#      Copy this file to .env: cp .env.example .env
#   2) แก้ค่าด้านล่างให้ตรงกับของคุณ / Fill in your own values below.
#   3) ห้าม commit ไฟล์ .env เข้า git เด็ดขาด! (ควรอยู่ใน .gitignore แล้ว)
#      NEVER commit the real .env file to git! (should already be in .gitignore)
# =============================================================================

# -----------------------------------------------------------------------------
# 🔐 คำเตือนสำคัญ: การตั้งค่า Binance API Key ให้ปลอดภัย (อ่านก่อนสร้างคีย์!)
#    IMPORTANT: Hardening your Binance API key (read before creating a key!)
# -----------------------------------------------------------------------------
# เวลาสร้าง API Key บน Binance ให้ตั้งค่าดังนี้เสมอ:
# When creating your API key on Binance, ALWAYS configure it like this:
#
#   1. เปิดใช้เฉพาะ "Enable Spot & Margin Trading" (Spot Trading only)
#      Enable ONLY "Spot Trading" permission — ไม่ต้องเปิด Margin/Futures
#
#   2. ปิดการถอนเงินให้สนิท "Enable Withdrawals" = DISABLED เสมอ
#      Withdrawals permission must be DISABLED. Always. No exceptions.
#      แม้ bot จะโดนแฮ็ก เงินก็ถอนออกไปไม่ได้ ถ้าปิดสิทธิ์นี้
#      Even if the bot/key is compromised, funds cannot be withdrawn if this
#      permission is off — this is your single most important safety net.
#
#   3. ตั้ง IP Access Restriction / IP allowlist ให้เหลือเฉพาะ IP เครื่องที่รัน bot
#      Set an IP allowlist restricting the key to only the IP(s) running this
#      bot (your home IP / server IP). Do NOT leave it as "Unrestricted".
#
#   4. เก็บ Secret Key เป็นความลับสูงสุด ห้ามแชร์ ห้ามแปะในแชท ห้าม commit
#      Keep the secret key strictly private — never share it, never paste it
#      in chat/screenshots, never commit it to any repository.
#
#   5. หากสงสัยว่าคีย์หลุด ให้ไปลบ/หมุนคีย์ (revoke & regenerate) บน Binance ทันที
#      If you suspect the key leaked, revoke/regenerate it on Binance immediately.
#
#   สรุป: Spot only + Withdrawals OFF + IP allowlist = แม้พลาดก็เสียหายจำกัด
#   Summary: Spot-only + Withdrawals-OFF + IP-allowlist = damage stays bounded
#   even in the worst case (leaked key, bug, or a rogue LLM response).
# -----------------------------------------------------------------------------

# Binance API Key / Secret
# คีย์ Binance ของคุณ (ดูคำเตือนด้านบนก่อนสร้างคีย์)
# Your Binance API credentials (read the hardening note above before creating)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# OpenRouter API Key — ใช้เรียก LLM ที่เป็น "สมอง" ตัดสินใจของ bot
# OpenRouter API key — powers the LLM that acts as the bot's decision brain.
# สมัคร/ดูคีย์ได้ที่ https://openrouter.ai/keys
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# โมเดล LLM ที่จะใช้ผ่าน OpenRouter (ใช้ slug ของ OpenRouter ตัวไหนก็ได้ที่รองรับ
# chat completions — ตัวอย่างด้านล่างคือค่าเริ่มต้น ไม่บังคับต้องใช้ตัวนี้)
# Which LLM model to use via OpenRouter. ANY valid OpenRouter model slug works
# here (Claude, GPT, Llama, Gemini, etc.) — this is just a sensible default.
# ดูรายชื่อโมเดลทั้งหมดที่ https://openrouter.ai/models
# See the full model list at https://openrouter.ai/models
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# คู่เหรียญที่จะเทรด (รูปแบบ ccxt เช่น BTC/USDT, ETH/USDT)
# Trading pair symbol, ccxt format (e.g. BTC/USDT, ETH/USDT)
SYMBOL=BTC/USDT

# กรอบเวลาแท่งเทียนที่ใช้วิเคราะห์ (1m, 5m, 15m, 1h, 4h, 1d, ...)
# Candle timeframe used for analysis (1m, 5m, 15m, 1h, 4h, 1d, ...)
TIMEFRAME=1h

# -----------------------------------------------------------------------------
# 🛡️ สวิตช์ความปลอดภัยหลัก / Core safety switches
# -----------------------------------------------------------------------------

# DRY_RUN=true (ค่าเริ่มต้น) → bot จะ "จำลอง" การเทรดเท่านั้น ไม่ส่งคำสั่งจริงเด็ดขาด
# มีแค่การ log ว่า "ถ้าเทรดจริงจะทำอะไร" เท่านั้น ปลอดภัย 100% สำหรับทดสอบ
# DRY_RUN=true (default) → the bot only SIMULATES trading, it NEVER places a
# real order. It just logs what it *would* do. Safe by default for testing.
# ต้องตั้งเป็น false เองเท่านั้นถึงจะมีโอกาสส่งคำสั่งจริง (ต้องผ่านเงื่อนไขอื่นด้วย)
# You must explicitly set this to false to even have a chance of live trading
# (and several other conditions below must ALSO be satisfied — see autotrade.py).
DRY_RUN=true

# USE_TESTNET=true (ค่าเริ่มต้น) → ใช้ Binance Testnet (เงินปลอม/ทดสอบ) ผ่าน
# ccxt sandbox mode ไม่แตะเงินจริงแม้ DRY_RUN=false
# USE_TESTNET=true (default) → uses Binance TESTNET (fake/sandbox funds) via
# ccxt's sandbox mode. No real money is at risk even if DRY_RUN=false.
# ต้องตั้ง false เองเท่านั้นถึงจะไปแตะ Binance mainnet (เงินจริง) — ระวังให้มาก!
# Set to false ONLY when you deliberately want Binance MAINNET (real money).
# This is a serious decision — see the extra safeguards in autotrade.py.
USE_TESTNET=true

# -----------------------------------------------------------------------------
# 💰 การจำกัดความเสี่ยง / Risk limits
# -----------------------------------------------------------------------------

# วงเงินสูงสุดต่อ 1 คำสั่ง (หน่วย USDT) — bot จะไม่มีวันส่งคำสั่งที่มูลค่าเกินนี้
# Maximum notional value per single order, in USDT. The bot will never place
# an order larger than this, no matter what the LLM suggests.
MAX_ORDER_USDT=15

# ขาดทุนสะสมสูงสุดต่อวัน/ต่อ session (หน่วย USDT) — ถ้าขาดทุนถึงระดับนี้ bot จะ
# หยุดเทรดทันทีและออกจากโปรแกรม (ต้องรีสตาร์ทเองเพื่อเทรดต่อ)
# Maximum realized loss per day/session, in USDT. If losses reach this level,
# the bot halts trading immediately and exits (must be restarted manually).
MAX_DAILY_LOSS_USDT=50

# -----------------------------------------------------------------------------
# ⏱️ จังหวะการทำงาน / Timing
# -----------------------------------------------------------------------------

# ระยะพักระหว่างแต่ละรอบตัดสินใจ (หน่วยวินาที)
# Sleep interval between each decision cycle, in seconds.
POLL_INTERVAL_SEC=300

# จำนวนแท่งเทียนย้อนหลังที่ดึงมาคำนวณ indicator (SMA/RSI/high-low)
# Number of historical candles fetched to compute indicators (SMA/RSI/high-low).
CANDLE_LOOKBACK=60

# =============================================================================
# หมายเหตุ / NOTES:
# - บอทนี้เป็นซอฟต์แวร์ทดลอง (experimental) การเทรดคริปโตมีความเสี่ยงสูงมาก
#   คุณอาจสูญเสียเงินทั้งหมดได้ นี่ไม่ใช่คำแนะนำการลงทุน คุณต้องรับผิดชอบผลลัพธ์
#   ทั้งหมดด้วยตัวเอง
#   This bot is experimental software. Crypto trading is HIGH RISK — you can
#   lose all of your money. This is NOT financial advice. You are solely
#   responsible for any outcome from running this software.
# - การเทรดเงินจริง (real money) ต้องผ่านเงื่อนไขทั้งหมดนี้พร้อมกัน:
#   Live real-money trading requires ALL of the following simultaneously:
#     1) DRY_RUN=false ในไฟล์นี้ / in this file
#     2) รัน script พร้อม flag --live / running with the --live CLI flag
#     3) พิมพ์ยืนยัน "I UNDERSTAND" ตอนโปรแกรมเริ่มทำงาน (interactive prompt)
#        typing "I UNDERSTAND" at the interactive startup confirmation prompt
#     4) ถ้า USE_TESTNET=false (mainnet) ต้องตั้ง env เพิ่ม:
#        if USE_TESTNET=false (mainnet), you must ALSO set:
#        I_UNDERSTAND_REAL_MONEY=YES
#   ขาดข้อใดข้อหนึ่ง → บอทจะปฏิเสธเทรดจริงและกลับไปเป็น dry-run โดยอัตโนมัติ
#   Missing any ONE of these → the bot refuses live trading and automatically
#   falls back to dry-run mode.
# =============================================================================
